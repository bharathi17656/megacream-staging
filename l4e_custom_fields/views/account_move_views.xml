<odoo>
    <record id="view_move_form_inherit_contact_numbers" model="ir.ui.view">
        <field name="name">account.move.form.contact.numbers</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='l10n_in_gst_treatment']" position="after">
                <field name="accounts_contact_number"/>
                <field name="sales_contact_number"/>
            </xpath>

        </field>
    </record>
</odoo>