<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Inherit res.users form to add Store Indent field
         in the Preferences / Work Information tab
         ============================================================ -->
    <record id="res_users_form_store_indent" model="ir.ui.view">
        <field name="name">res.users.form.store.indent</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Add Store Indent field in the Access Rights tab -->
            <xpath expr="//page[@name='access_rights']" position="inside">
                <separator string="Purchase Settings"/>
                <group>
                    <field name="store_indent"
                           string="Store Indent User"
                           widget="boolean_toggle"
                           help="When enabled, this user does not need to specify a vendor in Draft state for Purchase Orders. This is intended for warehouse/store staff creating indent requests."/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         Inherit res.users simplified form (Settings > Users list)
         ============================================================ -->
    <record id="res_users_simple_form_store_indent" model="ir.ui.view">
        <field name="name">res.users.simple.form.store.indent</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_simple_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="Purchase Settings">
                    <field name="store_indent"
                           string="Store Indent User"
                           widget="boolean_toggle"
                           help="When enabled, this user does not need to specify a vendor in Draft state."/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
