    <!-- ============================================================
         RFQ List View - Add Draft state
         ============================================================ -->
    <record id="purchase_rfq_list_draft_inherit" model="ir.ui.view">
        <field name="name">purchase.rfq.list.draft.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" optional="show"
                       widget="badge"
                       decoration-warning="approval_state == 'pending'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'refused'"
                       string="Approval Status"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         Action: Pending Approvals - for Procurement Managers
         ============================================================ -->
    <record id="action_purchase_draft_pending_approval" model="ir.actions.act_window">
        <field name="name">Pending RFQ Approvals</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'draft_indent'), ('approval_state', '=', 'pending')]</field>
        <field name="context">{'default_state': 'draft_indent'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending RFQ approvals!
            </p>
            <p>
                Purchase orders awaiting RFQ approval will appear here.
            </p>
        </field>
    </record>

    <!-- ============================================================
         Menu: Pending Approvals under Orders menu
         ============================================================ -->
    <menuitem
        id="menu_purchase_draft_pending_approval"
        name="Pending RFQ Approvals"
        parent="purchase.menu_purchase_root"
        action="action_purchase_draft_pending_approval"
        groups="purchase.group_purchase_manager"
        sequence="15"/>

</odoo>
